.mypy_cache/
.ruff_cache/

# ─── Virtual environments ───────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── NBIS artifacts (large files — not for git) ─────────────────────────
# The trained model, FAISS index, mapping, threshold, preprocessing config,
# and SQLite database all live in artifacts/ and should never be committed.
# Keep the README so the folder survives a clone.
artifacts/*
!artifacts/README.md
!artifacts/.gitkeep

